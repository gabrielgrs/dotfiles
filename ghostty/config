keybind = "cmd+t=ignore"
keybind = "cmd+n=ignore"

font-size = 16
mouse-hide-while-typing = true
background-opacity = 0.97
background-blur-radius = 40

font-feature=liga
font-thicken=true

theme = Catppuccin Mocha

shell-integration-features = true
copy-on-select = clipboard
focus-follows-mouse = true
link-url = true

confirm-close-surface = true
window-decoration = true
window-padding-x = 4
window-padding-y = 4
window-padding-balance = true
cursor-invert-fg-bg = true

macos-option-as-alt = true

keybind = command+digit_1=text:\x011
keybind = command+digit_2=text:\x012
keybind = command+digit_3=text:\x013
keybind = command+digit_4=text:\x014
keybind = command+digit_5=text:\x015
keybind = command+digit_6=text:\x016
keybind = command+digit_7=text:\x017
keybind = command+digit_8=text:\x018
keybind = command+digit_9=text:\x019